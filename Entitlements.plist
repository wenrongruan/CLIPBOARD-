<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App 标识符（必须与 Provisioning Profile 匹配） -->
    <key>com.apple.application-identifier</key>
    <string>N9B2B6LN88.com.wenrongruan.sharedclipboard</string>

    <!-- Team ID -->
    <key>com.apple.developer.team-identifier</key>
    <string>N9B2B6LN88</string>

    <!-- App Sandbox（Mac App Store 强制要求；沙盒下 pynput 全局热键会失效，仅 DevID 版可用） -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!-- 网络客户端访问（MySQL 多设备同步功能） -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- 用户选择的文件读写（通过文件对话框导入/导出数据库、导入常用文件） -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- 允许持久化 security-scoped bookmark，跨进程重启仍可定位用户选中的源文件 -->
    <key>com.apple.security.files.bookmarks.app-scope</key>
    <true/>

    <!-- 允许写入用户 Downloads 目录（用于 "下载到本地" 导出） -->
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>
</dict>
</plist>
