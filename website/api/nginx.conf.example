# SharedClipboard API 路由配置
# 将此内容粘贴到宝塔面板 → 网站 → 站点设置 → 配置文件 中
# 放在 server { } 块内

# API 路由 — 所有 /api/ 请求转发到 PHP 入口
location /api/ {
    try_files $uri $uri/ /api/index.php?$query_string;
}

# 禁止直接访问 config.php 和 lib 目录
location ~ ^/api/(config\.php|lib/|controllers/|install\.php) {
    deny all;
    return 403;
}

